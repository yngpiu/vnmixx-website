# App runtime variables (apps/api)
PORT=4000
DATABASE_URL="mysql://vnmixx:vnmixx@127.0.0.1:3306/vnmixx?allowPublicKeyRetrieval=true"

# Redis connection (ưu tiên REDIS_URL nếu có)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production

# SMTP (optional in local dev; OTP will be logged if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VNMIXX <no-reply@vnmixx.vn>"

# GHN (Giao Hàng Nhanh) - Shipping
# Production: https://online-gateway.ghn.vn/shiip/public-api/v2
# Dev:        https://dev-online-gateway.ghn.vn/shiip/public-api/v2
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2
GHN_TOKEN=your_ghn_token_here
GHN_SHOP_ID=your_shop_id_here
# GHN ID của quận/huyện và phường/xã kho lấy hàng (lấy từ API master-data của GHN)
GHN_SHOP_DISTRICT_ID=your_district_ghn_id
GHN_SHOP_WARD_ID=your_ward_ghn_id

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
# Public base for media URLs (no trailing slash), e.g. https://media.vnmixx.shop — full URL is `${R2_PUBLIC_URL}/${objectKey}` (not stored in DB).
R2_PUBLIC_URL=https://your-media-cdn.example.com
