# App runtime variables (apps/api)
PORT=4000
DATABASE_URL="mysql://vnmixx:vnmixx@127.0.0.1:3306/vnmixx"

# Redis connection (ưu tiên REDIS_URL nếu có)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-in-production
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# Customer OTP
CUSTOMER_OTP_EXPIRATION=300
CUSTOMER_OTP_RESEND_COOLDOWN=60
CUSTOMER_OTP_MAX_ATTEMPTS=5

# SMTP (optional in local dev; OTP will be logged if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VNMIXX <no-reply@vnmixx.vn>"

# Bcrypt
BCRYPT_SALT_ROUNDS=12
