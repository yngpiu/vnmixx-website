generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AddressType {
  HOME
  OFFICE
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_CONFIRMATION
  PROCESSING
  AWAITING_SHIPMENT
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  BANK_TRANSFER_QR
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum SepayTransferType {
  IN
  OUT
}

enum SepayMatchStatus {
  MATCHED
  UNMATCHED
  DUPLICATE
  IGNORED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum RequiredNote {
  CHOTHUHANG
  CHOXEMHANGKHONGTHU
  KHONGCHOXEMHANG
}

enum StockMovementType {
  IMPORT
  EXPORT
  RESERVE
  RELEASE
  ADJUSTMENT
  RETURN
}

enum InventoryVoucherType {
  IMPORT
  EXPORT
}

enum InventoryVoucherStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum AuditLogStatus {
  SUCCESS
  FAILED
}

enum ChatSenderType {
  CUSTOMER
  EMPLOYEE
}

enum ReviewVisibility {
  VISIBLE
  HIDDEN
}

model Customer {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  fullName        String    @map("full_name") @db.VarChar(100)
  email           String    @unique(map: "uk_customers_email") @db.VarChar(255)
  phoneNumber     String    @unique(map: "uk_customers_phone") @map("phone_number") @db.VarChar(20)
  dob             DateTime? @db.Date
  gender          Gender?
  hashedPassword  String    @map("hashed_password") @db.VarChar(255)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  isActive        Boolean   @default(true) @map("is_active") @db.TinyInt
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamp(0)

  refreshTokens  RefreshToken[]
  addresses      Address[]
  cart           Cart?
  wishlists      Wishlist[]
  orders         Order[]
  productReviews ProductReview[]
  supportChats   SupportChat[]
  chatMessages   ChatMessage[] @relation("ChatMessageSenderCustomer")

  @@map("customers")
}

model Employee {
  id             Int            @id @default(autoincrement()) @db.UnsignedInt
  roleId         Int            @map("role_id") @db.UnsignedInt
  fullName       String         @map("full_name") @db.VarChar(100)
  email          String         @unique(map: "uk_employees_email") @db.VarChar(255)
  phoneNumber    String         @unique(map: "uk_employees_phone") @map("phone_number") @db.VarChar(20)
  hashedPassword String         @map("hashed_password") @db.VarChar(255)
  avatarUrl      String?        @map("avatar_url") @db.VarChar(500)
  status         EmployeeStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamp(0)

  role             Role             @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refreshTokens    RefreshToken[]
  inventoryVouchers InventoryVoucher[]
  stockMovements   StockMovement[]
  mediaFiles       MediaFile[]
  auditLogsAsActor AuditLog[]       @relation("AuditLogActor")
  chatAssignments  ChatAssignment[]
  chatMessages     ChatMessage[]    @relation("ChatMessageSenderEmployee")

  @@index([roleId], map: "idx_employees_role")
  @@map("employees")
}

model AuditLog {
  id              Int            @id @default(autoincrement()) @db.UnsignedInt
  actorEmployeeId Int?           @map("actor_employee_id") @db.UnsignedInt
  action          String         @db.VarChar(120)
  resourceType    String         @map("resource_type") @db.VarChar(80)
  resourceId      String?        @map("resource_id") @db.VarChar(64)
  requestId       String?        @map("request_id") @db.VarChar(64)
  ipAddress       String?        @map("ip_address") @db.VarChar(45)
  userAgent       String?        @map("user_agent") @db.VarChar(500)
  beforeData      Json?          @map("before_data")
  afterData       Json?          @map("after_data")
  status          AuditLogStatus
  errorMessage    String?        @map("error_message") @db.VarChar(500)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp(0)

  actorEmployee Employee? @relation("AuditLogActor", fields: [actorEmployeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([actorEmployeeId, createdAt], map: "idx_audit_logs_actor_created")
  @@index([resourceType, resourceId, createdAt], map: "idx_audit_logs_resource_created")
  @@index([action, createdAt], map: "idx_audit_logs_action_created")
  @@map("audit_logs")
}

model Role {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique(map: "uk_roles_name") @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  rolePermissions RolePermission[]
  employees       Employee[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique(map: "uk_permissions_name") @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedInt
  permissionId Int @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_role_perms_permission")
  @@map("role_permissions")
}

model City {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_cities_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  districts District[]
  addresses Address[]

  @@map("cities")
}

model District {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_districts_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  cityId          Int      @map("city_id") @db.UnsignedInt
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  city      City      @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  wards     Ward[]
  addresses Address[]

  @@index([cityId], map: "idx_districts_city")
  @@map("districts")
}

model Ward {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_wards_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  districtId      Int      @map("district_id") @db.UnsignedInt
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  district  District  @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  addresses Address[]

  @@index([districtId], map: "idx_wards_district")
  @@map("wards")
}

model Address {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  customerId  Int         @map("customer_id") @db.UnsignedInt
  fullName    String      @map("full_name") @db.VarChar(100)
  phoneNumber String      @map("phone_number") @db.VarChar(20)
  cityId      Int         @map("city_id") @db.UnsignedInt
  districtId  Int         @map("district_id") @db.UnsignedInt
  wardId      Int         @map("ward_id") @db.UnsignedInt
  addressLine String      @map("address_line") @db.VarChar(255)
  type        AddressType @default(HOME)
  isDefault   Boolean     @default(false) @map("is_default") @db.TinyInt
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamp(0)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  city     City     @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  district District @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ward     Ward     @relation(fields: [wardId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([customerId], map: "idx_addresses_customer")
  @@index([cityId], map: "idx_addresses_city")
  @@index([districtId], map: "idx_addresses_district")
  @@index([wardId], map: "idx_addresses_ward")
  @@map("addresses")
}

model Category {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  name       String    @db.VarChar(100)
  slug       String    @unique(map: "uk_categories_slug") @db.VarChar(120)
  isFeatured Boolean   @default(false) @map("is_featured") @db.TinyInt
  isActive   Boolean   @default(true) @map("is_active") @db.TinyInt
  sortOrder  Int       @default(0) @map("sort_order") @db.SmallInt
  parentId   Int?      @map("parent_id") @db.UnsignedInt
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  parent            Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children          Category[]        @relation("CategoryTree")
  productCategories ProductCategory[]

  @@index([parentId], map: "idx_categories_parent")
  @@map("categories")
}

model Color {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @unique(map: "uk_colors_name") @db.VarChar(50)
  hexCode   String   @unique(map: "uk_colors_hex") @map("hex_code") @db.Char(7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  variants ProductVariant[]
  images   ProductImage[]

  @@map("colors")
}

model Size {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  label     String   @unique(map: "uk_sizes_label") @db.VarChar(10)
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  variants ProductVariant[]

  @@map("sizes")
}

model Product {
  id          Int              @id @default(autoincrement()) @db.UnsignedInt
  name        String           @db.VarChar(255)
  slug        String           @unique(map: "uk_products_slug") @db.VarChar(255)
  description String?          @db.Text
  thumbnail   String?          @db.VarChar(500)
  isActive    Boolean          @default(true) @map("is_active") @db.TinyInt
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamp(0)

  productCategories ProductCategory[]
  variants          ProductVariant[]
  images            ProductImage[]
  wishlists         Wishlist[]
  reviews           ProductReview[]

  @@index([isActive, deletedAt], map: "idx_products_active_deleted")
  @@index([deletedAt], map: "idx_products_deleted_at")
  @@map("products")
}

model ProductCategory {
  productId  Int @map("product_id") @db.UnsignedInt
  categoryId Int @map("category_id") @db.UnsignedInt

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId], map: "idx_product_categories_category")
  @@map("product_categories")
}

model ProductVariant {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  productId Int       @map("product_id") @db.UnsignedInt
  colorId   Int       @map("color_id") @db.UnsignedInt
  sizeId    Int       @map("size_id") @db.UnsignedInt
  sku       String    @unique(map: "uk_variants_sku") @db.VarChar(50)
  barcode   String?   @unique(map: "uk_variants_barcode") @db.VarChar(64)
  unit      String    @default("pcs") @db.VarChar(20)
  price     Int       @db.UnsignedInt
  defaultCost Int?    @map("default_cost") @db.UnsignedInt
  onHand    Int       @default(0) @map("on_hand") @db.UnsignedInt
  reserved  Int       @default(0) @db.UnsignedInt
  version   Int       @default(0) @db.UnsignedInt
  isActive  Boolean   @default(true) @map("is_active") @db.TinyInt
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  color          Color           @relation(fields: [colorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  size           Size            @relation(fields: [sizeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cartItems      CartItem[]
  inventoryVoucherItems InventoryVoucherItem[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]

  @@unique([productId, colorId, sizeId], map: "uk_variants_combo")
  @@index([productId, isActive], map: "idx_variants_product_active")
  @@index([colorId], map: "idx_variants_color")
  @@index([sizeId], map: "idx_variants_size")
  @@map("product_variants")
}

model InventoryVoucher {
  id                 Int                    @id @default(autoincrement()) @db.UnsignedInt
  code               String                 @unique(map: "uk_inventory_vouchers_code") @db.VarChar(30)
  type               InventoryVoucherType
  status             InventoryVoucherStatus @default(CONFIRMED)
  issuedAt           DateTime               @map("issued_at") @db.Timestamp(0)
  note               String?                @db.VarChar(500)
  totalQuantity      Int                    @default(0) @map("total_quantity") @db.UnsignedInt
  totalAmount        Int                    @default(0) @map("total_amount") @db.UnsignedInt
  createdByEmployeeId Int                   @map("created_by_employee_id") @db.UnsignedInt
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamp(0)

  createdByEmployee Employee               @relation(fields: [createdByEmployeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items             InventoryVoucherItem[]
  stockMovements    StockMovement[]

  @@index([type, issuedAt], map: "idx_inventory_vouchers_type_issued")
  @@index([createdByEmployeeId], map: "idx_inventory_vouchers_created_by")
  @@map("inventory_vouchers")
}

model InventoryVoucherItem {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  voucherId   Int      @map("voucher_id") @db.UnsignedInt
  variantId   Int      @map("variant_id") @db.UnsignedInt
  quantity    Int      @db.UnsignedInt
  unitPrice   Int      @map("unit_price") @db.UnsignedInt
  lineAmount  Int      @map("line_amount") @db.UnsignedInt
  note        String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  voucher InventoryVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([voucherId, variantId], map: "uk_inventory_voucher_items_voucher_variant")
  @@index([variantId], map: "idx_inventory_voucher_items_variant")
  @@map("inventory_voucher_items")
}

model ProductImage {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  productId Int      @map("product_id") @db.UnsignedInt
  colorId   Int?     @map("color_id") @db.UnsignedInt
  url       String   @db.VarChar(500)
  altText   String?  @map("alt_text") @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([productId, colorId], map: "idx_images_product_color")
  @@map("product_images")
}

model ProductReview {
  id         Int              @id @default(autoincrement()) @db.UnsignedInt
  productId  Int              @map("product_id") @db.UnsignedInt
  customerId Int              @map("customer_id") @db.UnsignedInt
  rating     Int              @db.UnsignedTinyInt
  title      String?          @db.VarChar(120)
  content    String?          @db.VarChar(1000)
  status     ReviewVisibility @default(VISIBLE)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamp(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([productId, customerId], map: "uk_product_reviews_product_customer")
  @@index([productId, createdAt], map: "idx_product_reviews_product_created")
  @@index([productId, rating], map: "idx_product_reviews_product_rating")
  @@index([rating, createdAt], map: "idx_product_reviews_rating_created")
  @@index([status, createdAt], map: "idx_product_reviews_status_created")
  @@map("product_reviews")
}

model Cart {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  customerId Int      @unique(map: "uk_carts_customer") @map("customer_id") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  cartId    Int      @map("cart_id") @db.UnsignedInt
  variantId Int      @map("variant_id") @db.UnsignedInt
  quantity  Int      @default(1) @db.UnsignedSmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([cartId, variantId], map: "uk_cart_items_combo")
  @@index([variantId], map: "idx_cart_items_variant")
  @@map("cart_items")
}

model Wishlist {
  customerId Int      @map("customer_id") @db.UnsignedInt
  productId  Int      @map("product_id") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([customerId, productId])
  @@index([productId], map: "idx_wishlists_product")
  @@map("wishlists")
}

model Order {
  id                    Int           @id @default(autoincrement()) @db.UnsignedInt
  orderCode             String        @unique(map: "uk_orders_code") @map("order_code") @db.VarChar(20)
  paymentCode           String        @unique(map: "uk_orders_payment_code") @map("payment_code") @db.VarChar(64)
  customerId            Int           @map("customer_id") @db.UnsignedInt
  status                OrderStatus   @default(PENDING_CONFIRMATION)
  shippingFullName      String        @map("shipping_full_name") @db.VarChar(100)
  shippingPhoneNumber   String        @map("shipping_phone_number") @db.VarChar(20)
  shippingCity          String        @map("shipping_city") @db.VarChar(100)
  shippingDistrict      String        @map("shipping_district") @db.VarChar(100)
  shippingWard          String        @map("shipping_ward") @db.VarChar(100)
  shippingAddressLine   String        @map("shipping_address_line") @db.VarChar(255)
  shippingGhnDistrictId Int?          @map("shipping_ghn_district_id") @db.UnsignedInt
  shippingGhnWardCode   String?       @map("shipping_ghn_ward_code") @db.VarChar(20)
  serviceTypeId         Int?          @map("service_type_id") @db.UnsignedSmallInt
  requiredNote          RequiredNote  @default(KHONGCHOXEMHANG) @map("required_note")
  note                  String?       @db.VarChar(500)
  ghnOrderCode          String?       @map("ghn_order_code") @db.VarChar(50)
  expectedDeliveryTime  DateTime?     @map("expected_delivery_time") @db.Timestamp(0)
  packageWeight         Int           @default(0) @map("package_weight") @db.UnsignedInt
  packageLength         Int           @default(0) @map("package_length") @db.UnsignedSmallInt
  packageWidth          Int           @default(0) @map("package_width") @db.UnsignedSmallInt
  packageHeight         Int           @default(0) @map("package_height") @db.UnsignedSmallInt
  couponCode            String?       @map("coupon_code") @db.VarChar(50)
  subtotal              Int           @db.UnsignedInt
  discountAmount        Int           @default(0) @map("discount_amount") @db.UnsignedInt
  shippingFee           Int           @default(0) @map("shipping_fee") @db.UnsignedInt
  total                 Int           @db.UnsignedInt
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamp(0)

  customer          Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items             OrderItem[]
  statusHistories   OrderStatusHistory[]
  payments          Payment[]
  sepayTransactions SepayTransaction[]
  stockMovements    StockMovement[]

  @@index([customerId], map: "idx_orders_customer")
  @@index([customerId, createdAt(sort: Desc)], map: "idx_orders_customer_created")
  @@index([status], map: "idx_orders_status")
  @@index([ghnOrderCode], map: "idx_orders_ghn_code")
  @@map("orders")
}

model OrderItem {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  orderId     Int      @map("order_id") @db.UnsignedInt
  variantId   Int      @map("variant_id") @db.UnsignedInt
  productName String   @map("product_name") @db.VarChar(255)
  colorName   String   @map("color_name") @db.VarChar(50)
  sizeLabel   String   @map("size_label") @db.VarChar(10)
  sku         String   @db.VarChar(50)
  price       Int      @db.UnsignedInt
  quantity    Int      @db.UnsignedSmallInt
  subtotal    Int      @db.UnsignedInt
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stockMovements StockMovement[] @relation("StockMovementOrderItem")

  @@index([orderId], map: "idx_order_items_order")
  @@index([variantId], map: "idx_order_items_variant")
  @@unique([id, orderId], map: "uk_order_items_id_order")
  @@map("order_items")
}

model OrderStatusHistory {
  id        Int         @id @default(autoincrement()) @db.UnsignedInt
  orderId   Int         @map("order_id") @db.UnsignedInt
  status    OrderStatus
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamp(0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderId], map: "idx_status_histories_order")
  @@map("order_status_histories")
}

model Payment {
  id                    Int           @id @default(autoincrement()) @db.UnsignedInt
  orderId               Int           @unique(map: "uk_payments_order") @map("order_id") @db.UnsignedInt
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  provider              String?       @db.VarChar(30)
  transactionId         String?       @map("transaction_id") @db.VarChar(100)
  providerReferenceCode String?       @map("provider_reference_code") @db.VarChar(100)
  bankCode              String?       @map("bank_code") @db.VarChar(30)
  bankName              String?       @map("bank_name") @db.VarChar(100)
  accountNumber         String?       @map("account_number") @db.VarChar(50)
  accountName           String?       @map("account_name") @db.VarChar(150)
  qrTemplate            String?       @map("qr_template") @db.VarChar(30)
  transferContent       String?       @map("transfer_content") @db.VarChar(255)
  qrImageUrl            String?       @map("qr_image_url") @db.VarChar(1000)
  amount                Int           @db.UnsignedInt
  amountPaid            Int           @default(0) @map("amount_paid") @db.UnsignedInt
  paidAt                DateTime?     @map("paid_at") @db.Timestamp(0)
  expiredAt             DateTime?     @map("expired_at") @db.Timestamp(0)
  lastPayloadReceivedAt DateTime?     @map("last_payload_received_at") @db.Timestamp(0)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamp(0)

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sepayTransactions SepayTransaction[]

  @@index([transactionId], map: "idx_payments_transaction")
  @@index([status, expiredAt], map: "idx_payments_status_expired")
  @@map("payments")
}

model SepayTransaction {
  id                Int               @id @default(autoincrement()) @db.UnsignedInt
  sepayTransactionId Int              @unique(map: "uk_sepay_transactions_sepay_id") @map("sepay_transaction_id") @db.UnsignedInt
  gateway           String            @db.VarChar(100)
  transactionDate   DateTime          @map("transaction_date") @db.Timestamp(0)
  accountNumber     String?           @map("account_number") @db.VarChar(100)
  subAccount        String?           @map("sub_account") @db.VarChar(250)
  transferType      SepayTransferType @map("transfer_type")
  transferAmount    Int               @map("transfer_amount") @db.UnsignedInt
  accumulated       Int?              @db.UnsignedInt
  code              String?           @db.VarChar(250)
  content           String            @db.VarChar(1000)
  referenceCode     String?           @map("reference_code") @db.VarChar(255)
  description       String?           @db.Text
  orderId           Int?              @map("order_id") @db.UnsignedInt
  paymentId         Int?              @map("payment_id") @db.UnsignedInt
  matchedPaymentCode String?          @map("matched_payment_code") @db.VarChar(64)
  matchStatus       SepayMatchStatus  @default(UNMATCHED) @map("match_status")
  rawPayload        Json              @map("raw_payload")
  receivedAt        DateTime          @default(now()) @map("received_at") @db.Timestamp(0)
  processedAt       DateTime?         @map("processed_at") @db.Timestamp(0)

  order   Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([orderId], map: "idx_sepay_transactions_order")
  @@index([paymentId], map: "idx_sepay_transactions_payment")
  @@index([matchedPaymentCode], map: "idx_sepay_transactions_payment_code")
  @@index([referenceCode], map: "idx_sepay_transactions_reference")
  @@index([transferType, receivedAt], map: "idx_sepay_transactions_type_received")
  @@map("sepay_transactions")
}

model StockMovement {
  id            Int               @id @default(autoincrement()) @db.UnsignedInt
  variantId     Int               @map("variant_id") @db.UnsignedInt
  voucherId     Int?              @map("voucher_id") @db.UnsignedInt
  orderId       Int?              @map("order_id") @db.UnsignedInt
  orderItemId   Int?              @map("order_item_id") @db.UnsignedInt
  employeeId    Int?              @map("employee_id") @db.UnsignedInt
  type          StockMovementType
  delta         Int               @db.Int
  onHandAfter   Int               @map("on_hand_after") @db.UnsignedInt
  reservedAfter Int               @map("reserved_after") @db.UnsignedInt
  note          String?           @db.VarChar(255)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamp(0)

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  voucher   InventoryVoucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  order     Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  orderItem OrderItem?     @relation("StockMovementOrderItem", fields: [orderItemId, orderId], references: [id, orderId], onDelete: SetNull, onUpdate: Cascade)
  employee  Employee?      @relation(fields: [employeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([variantId, createdAt], map: "idx_stock_movements_variant_created")
  @@index([voucherId, createdAt], map: "idx_stock_movements_voucher_created")
  @@index([variantId, type, createdAt], map: "idx_stock_movements_variant_type_created")
  @@index([orderId], map: "idx_stock_movements_order")
  @@index([orderItemId], map: "idx_stock_movements_order_item")
  @@index([employeeId], map: "idx_stock_movements_employee")
  @@index([type, createdAt], map: "idx_stock_movements_type_created")
  @@map("stock_movements")
}

model RefreshToken {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  tokenHash  String    @unique(map: "uk_refresh_token_hash") @map("token_hash") @db.VarChar(255)
  customerId Int?      @map("customer_id") @db.UnsignedInt
  employeeId Int?      @map("employee_id") @db.UnsignedInt
  deviceInfo String?   @map("device_info") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(0)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([customerId], map: "idx_refresh_customer")
  @@index([employeeId], map: "idx_refresh_employee")
  @@index([customerId, employeeId], map: "idx_refresh_owner_pair")
  @@index([expiresAt], map: "idx_refresh_expires")
  @@index([revokedAt], map: "idx_refresh_revoked")
  @@map("refresh_tokens")
}

model MediaFile {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  key        String   @unique(map: "uk_media_key") @db.VarChar(500)
  fileName   String   @map("file_name") @db.VarChar(255)
  folder     String   @default("") @db.VarChar(500)
  folderId   Int?     @map("folder_id") @db.UnsignedInt
  mimeType   String   @map("mime_type") @db.VarChar(100)
  size       Int      @db.UnsignedInt
  width      Int?     @db.UnsignedSmallInt
  height     Int?     @db.UnsignedSmallInt
  uploadedBy Int?     @map("uploaded_by") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  mediaFolder MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employee    Employee?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([folder], map: "idx_media_folder")
  @@index([folderId], map: "idx_media_folder_id")
  @@index([mimeType], map: "idx_media_mime")
  @@index([uploadedBy], map: "idx_media_uploaded_by")
  @@map("media_files")
}

model MediaFolder {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @db.VarChar(255)
  parentId  Int?     @map("parent_id") @db.UnsignedInt
  path      String   @unique(map: "uk_media_folder_path") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  parent   MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  children MediaFolder[] @relation("FolderTree")
  files    MediaFile[]

  @@index([parentId], map: "idx_folder_parent")
  @@map("media_folders")
}

model SupportChat {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  customerId Int      @unique(map: "uk_support_chats_customer") @map("customer_id") @db.UnsignedInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  customer    Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  messages    ChatMessage[]
  assignments ChatAssignment[]

  @@index([updatedAt], map: "idx_support_chats_updated")
  @@map("support_chats")
}

model ChatMessage {
  id               Int            @id @default(autoincrement()) @db.UnsignedInt
  chatId           Int            @map("chat_id") @db.UnsignedInt
  senderType       ChatSenderType @map("sender_type")
  senderCustomerId Int?           @map("sender_customer_id") @db.UnsignedInt
  senderEmployeeId Int?           @map("sender_employee_id") @db.UnsignedInt
  content          String         @db.VarChar(2000)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamp(0)

  chat            SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  senderCustomer  Customer?   @relation("ChatMessageSenderCustomer", fields: [senderCustomerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  senderEmployee  Employee?   @relation("ChatMessageSenderEmployee", fields: [senderEmployeeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([chatId, createdAt], map: "idx_chat_messages_chat_created")
  @@index([senderCustomerId], map: "idx_chat_messages_sender_customer")
  @@index([senderEmployeeId], map: "idx_chat_messages_sender_employee")
  @@map("chat_messages")
}

model ChatAssignment {
  chatId     Int      @map("chat_id") @db.UnsignedInt
  employeeId Int      @map("employee_id") @db.UnsignedInt
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamp(0)

  chat     SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([chatId, employeeId])
  @@index([employeeId], map: "idx_chat_assignments_employee")
  @@map("chat_assignments")
}
