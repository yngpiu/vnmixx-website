// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ───────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AddressType {
  HOME
  OFFICE
}

// ─── Customers ───────────────────────────────────────────

model Customer {
  id              Int       @id @default(autoincrement()) @db.UnsignedInt
  fullName        String    @map("full_name") @db.VarChar(100)
  email           String    @unique(map: "uk_customers_email") @db.VarChar(255)
  phoneNumber     String    @unique(map: "uk_customers_phone") @map("phone_number") @db.VarChar(20)
  dob             DateTime? @db.Date
  gender          Gender?
  hashedPassword  String    @map("hashed_password") @db.VarChar(255)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  isActive        Boolean   @default(true) @map("is_active") @db.TinyInt
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamp(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamp(0)

  refreshTokens RefreshToken[]
  addresses     Address[]

  @@map("customers")
}

// ─── Employees ───────────────────────────────────────────

model Employee {
  id             Int       @id @default(autoincrement()) @db.UnsignedInt
  fullName       String    @map("full_name") @db.VarChar(100)
  email          String    @unique(map: "uk_employees_email") @db.VarChar(255)
  phoneNumber    String    @unique(map: "uk_employees_phone") @map("phone_number") @db.VarChar(20)
  hashedPassword String    @map("hashed_password") @db.VarChar(255)
  avatarUrl      String?   @map("avatar_url") @db.VarChar(500)
  isActive       Boolean   @default(true) @map("is_active") @db.TinyInt
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp(0)

  employeeRoles EmployeeRole[]
  refreshTokens RefreshToken[]

  @@map("employees")
}

// ─── RBAC ────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique(map: "uk_roles_name") @db.VarChar(50)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  rolePermissions RolePermission[]
  employeeRoles   EmployeeRole[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String   @unique(map: "uk_permissions_name") @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id") @db.UnsignedInt
  permissionId Int @map("permission_id") @db.UnsignedInt

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_role_perms_permission")
  @@map("role_permissions")
}

model EmployeeRole {
  employeeId Int @map("employee_id") @db.UnsignedInt
  roleId     Int @map("role_id") @db.UnsignedInt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([employeeId, roleId])
  @@index([roleId], map: "idx_emp_roles_role")
  @@map("employee_roles")
}

// ─── Geography ───────────────────────────────────────────

model City {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_cities_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  districts District[]
  addresses Address[]

  @@map("cities")
}

model District {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_districts_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  cityId          Int      @map("city_id") @db.UnsignedInt
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  city      City      @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  wards     Ward[]
  addresses Address[]

  @@index([cityId], map: "idx_districts_city")
  @@map("districts")
}

model Ward {
  id              Int      @id @default(autoincrement()) @db.UnsignedInt
  giaohangnhanhId String   @unique(map: "uk_wards_ghn") @map("giaohangnhanh_id") @db.VarChar(20)
  name            String   @db.VarChar(100)
  districtId      Int      @map("district_id") @db.UnsignedInt
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  district  District  @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  addresses Address[]

  @@index([districtId], map: "idx_wards_district")
  @@map("wards")
}

// ─── Addresses ───────────────────────────────────────────

model Address {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  customerId  Int         @map("customer_id") @db.UnsignedInt
  fullName    String      @map("full_name") @db.VarChar(100)
  phoneNumber String      @map("phone_number") @db.VarChar(20)
  cityId      Int         @map("city_id") @db.UnsignedInt
  districtId  Int         @map("district_id") @db.UnsignedInt
  wardId      Int         @map("ward_id") @db.UnsignedInt
  addressLine String      @map("address_line") @db.VarChar(255)
  type        AddressType @default(HOME)
  isDefault   Boolean     @default(false) @map("is_default") @db.TinyInt
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamp(0)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  city     City     @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  district District @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ward     Ward     @relation(fields: [wardId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([customerId], map: "idx_addresses_customer")
  @@index([cityId], map: "idx_addresses_city")
  @@index([districtId], map: "idx_addresses_district")
  @@index([wardId], map: "idx_addresses_ward")
  @@map("addresses")
}

// ─── Categories ──────────────────────────────────────────

model Category {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  name       String    @db.VarChar(100)
  slug       String    @unique(map: "uk_categories_slug") @db.VarChar(120)
  isFeatured Boolean   @default(false) @map("is_featured") @db.TinyInt
  sortOrder  Int       @default(0) @map("sort_order") @db.SmallInt
  parentId   Int?      @map("parent_id") @db.UnsignedInt
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamp(0)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId], map: "idx_categories_parent")
  @@map("categories")
}

// ─── Attributes (EAV) ───────────────────────────────────

model Attribute {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @unique(map: "uk_attributes_name") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  values AttributeValue[]

  @@map("attributes")
}

model AttributeValue {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  attributeId Int      @map("attribute_id") @db.UnsignedInt
  value       String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  attribute         Attribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productAttributes ProductAttribute[]

  @@unique([attributeId, value], map: "uk_attr_values_attr_value")
  @@map("attribute_values")
}

// ─── Colors & Sizes ─────────────────────────────────────

model Color {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  name      String   @unique(map: "uk_colors_name") @db.VarChar(50)
  hexCode   String   @unique(map: "uk_colors_hex") @map("hex_code") @db.Char(7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  variants ProductVariant[]
  images   ProductImage[]

  @@map("colors")
}

model Size {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  label     String   @unique(map: "uk_sizes_label") @db.VarChar(10)
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  variants ProductVariant[]

  @@map("sizes")
}

// ─── Products ───────────────────────────────────────────

model Product {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  categoryId  Int?      @map("category_id") @db.UnsignedInt
  name        String    @db.VarChar(255)
  slug        String    @unique(map: "uk_products_slug") @db.VarChar(255)
  description String?   @db.Text
  thumbnail   String?   @db.VarChar(500)
  isActive    Boolean   @default(true) @map("is_active") @db.TinyInt
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(0)

  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productAttributes ProductAttribute[]
  variants          ProductVariant[]
  images            ProductImage[]

  @@index([categoryId], map: "idx_products_category")
  @@map("products")
}

model ProductAttribute {
  productId        Int      @map("product_id") @db.UnsignedInt
  attributeValueId Int      @map("attribute_value_id") @db.UnsignedInt
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([productId, attributeValueId])
  @@map("product_attributes")
}

// ─── Product Variants & Images ──────────────────────────

model ProductVariant {
  id        Int       @id @default(autoincrement()) @db.UnsignedInt
  productId Int       @map("product_id") @db.UnsignedInt
  colorId   Int       @map("color_id") @db.UnsignedInt
  sizeId    Int       @map("size_id") @db.UnsignedInt
  sku       String    @unique(map: "uk_variants_sku") @db.VarChar(50)
  price     Int       @db.UnsignedInt
  salePrice Int?      @map("sale_price") @db.UnsignedInt
  stockQty  Int       @default(0) @map("stock_qty") @db.UnsignedInt
  isActive  Boolean   @default(true) @map("is_active") @db.TinyInt
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  color   Color   @relation(fields: [colorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  size    Size    @relation(fields: [sizeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([productId, colorId, sizeId], map: "uk_variants_combo")
  @@index([colorId], map: "idx_variants_color")
  @@index([sizeId], map: "idx_variants_size")
  @@map("product_variants")
}

model ProductImage {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  productId Int      @map("product_id") @db.UnsignedInt
  colorId   Int?     @map("color_id") @db.UnsignedInt
  url       String   @db.VarChar(500)
  altText   String?  @map("alt_text") @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([productId, colorId], map: "idx_images_product_color")
  @@map("product_images")
}

// ─── Refresh Tokens ──────────────────────────────────────

model RefreshToken {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  tokenHash  String    @unique(map: "uk_refresh_token_hash") @map("token_hash") @db.VarChar(255)
  customerId Int?      @map("customer_id") @db.UnsignedInt
  employeeId Int?      @map("employee_id") @db.UnsignedInt
  deviceInfo String?   @map("device_info") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(0)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamp(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(0)

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([customerId], map: "idx_refresh_customer")
  @@index([employeeId], map: "idx_refresh_employee")
  @@index([expiresAt], map: "idx_refresh_expires")
  @@map("refresh_tokens")
}
